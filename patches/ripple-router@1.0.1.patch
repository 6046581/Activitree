@@ -0,0 +1,68 @@
+import { effect, track } from 'ripple';
+import { NotFound } from '../components/NotFound.tsrx';
+import { RoutesContext } from '../contexts/RoutesContext.tsrx';
+import { formatPath } from '../utils/formatPath';
+import { matchPath } from '../utils/matchPath';
+import { getParams } from '../utils/getParams';
+import { SYMBOLS } from '../constants';
+
+function normalizePath(path: string): string {
+    if (path.length > 1 && path.endsWith('/')) {
+        return path.slice(0, -1);
+    }
+
+    return path;
+}
+
+export function Renderer() @{
+    const routes = RoutesContext.get();
+    let routeMatched = track(() => false);
+
+    // Get location pathname
+    let path = track(() => normalizePath(window.location.pathname));
+    let locationPathFragments = track(() => formatPath(path.value));
+    let element = track(null);
+    let params = track(null);
+
+    effect(() => {
+        function listenToNavigation() {
+            path.value = normalizePath(window.location.pathname);
+        }
+
+        window.addEventListener('popstate', listenToNavigation);
+        return () => window.removeEventListener('popstate', listenToNavigation);
+    })
+
+    effect(() => {
+        routeMatched.value = false;
+        element.value = null;
+        params.value = null;
+
+        for (const route of routes.keys()) {
+            const routePathFragments = formatPath(route);
+
+            if (matchPath(routePathFragments, locationPathFragments.value)) {
+                routeMatched.value = true;
+                element.value = routes.get(route);
+                params.value = getParams(routePathFragments, locationPathFragments.value);
+                break;
+            }
+        }
+    })
+
+    <>
+        @if (routeMatched.value) {
+            <{element.value} params={params.value} />
+        }
+        
+        @if (!routeMatched.value) {
+            const CustomNotFound = routes.get(SYMBOLS.CATCH_ALL);
+
+            @if (CustomNotFound) {
+                <{CustomNotFound} />
+            } @else {
+                <NotFound />
+            }
+        }
+    </>
+}
