<IfModule mod_rewrite.c>
    RewriteEngine On

    # Ignore /api paths
    RewriteRule ^api/ - [L]

    # Allow existing files
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule . index.html [L,QSA]
</IfModule>
