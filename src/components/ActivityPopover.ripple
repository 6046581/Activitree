import { track } from "ripple";

export component ActivityPopover() {
   let isAttending = track(false);

   const attendees = [
      {
         name: "John Person",
         avatar: "https://i.pravatar.cc/120?img=12",
      },
      {
         name: "Aisha Carter",
         avatar: "https://i.pravatar.cc/120?img=32",
      },
      {
         name: "Luca Moretti",
         avatar: "https://i.pravatar.cc/120?img=48",
      },
      {
         name: "Sofia Hernandez",
         avatar: "https://i.pravatar.cc/120?img=5",
      },
      {
         name: "Noah Kim",
         avatar: "https://i.pravatar.cc/120?img=18",
      },
      {
         name: "Maya Patel",
         avatar: "https://i.pravatar.cc/120?img=28",
      },
   ];

   function toggleAttendance() {
      @isAttending = !@isAttending;
   }

   function inviteOthers() {
      window.alert("Invite flow coming soon.");
   }

   <div class="popover">
      <article class="activity card">
         <div class="content">
            <section>
               <p class="hosting">{"Username is hosting:"}</p>
               <h4 class="title">{"Hiking in the Mountains"}</h4>
            </section>

            <p class="description">
               {"\"Join us for a refreshing hike through the scenic mountain trails. Perfect for all skill levels! This is a great opportunity to connect with nature and meet new people who share your love for the outdoors. Don't forget to bring water and wear comfortable shoes!\""}
            </p>

            <section class="details">
               <div class="info-box date-time">
                  <img
                     class="info-box-background"
                     src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aGlraW5nJTIwaW4lMjB0aGUlMjBtb3VudGFpbnN8ZW58MHx8MHx8fDA%3D&auto=format&fit=crop&w=800&q=60"
                     alt=""
                     aria-hidden="true"
                  />
                  <i class="fas fa-calendar-alt" />
                  <div>
                     <h4>{"Saturday at 9:00"}</h4>
                     <p>{"June 15th, 2024"}</p>
                  </div>
               </div>
               <div class="info-box location">
                  <img
                     class="info-box-background"
                     src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aGlraW5nJTIwaW4lMjB0aGUlMjBtb3VudGFpbnN8ZW58MHx8MHx8fDA%3D&auto=format&fit=crop&w=800&q=60"
                     alt=""
                     aria-hidden="true"
                  />
                  <i class="fas fa-map-marker-alt" />
                  <div>
                     <h4>{"PeePoo St. 24"}</h4>
                     <p>{"Blue Ridge Mountains, North Carolina"}</p>
                  </div>
               </div>
               <div class="info-box weather">
                  <img
                     class="info-box-background"
                     src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aGlraW5nJTIwaW4lMjB0aGUlMjBtb3VudGFpbnN8ZW58MHx8MHx8fDA%3D&auto=format&fit=crop&w=800&q=60"
                     alt=""
                     aria-hidden="true"
                  />
                  <i class="fas fa-cloud-sun" />
                  <div>
                     <h4>{"Sunny, 75°F"}</h4>
                     <p>{"Slight breeze or something idk"}</p>
                  </div>
               </div>
            </section>
         </div>
         <div class="aside">
            <img
               class="activity-cover"
               src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aGlraW5nJTIwaW4lMjB0aGUlMjBtb3VudGFpbnN8ZW58MHx8MHx8fDA%3D&auto=format&fit=crop&w=800&q=60"
               alt="Activity Image"
            />
            <section class="attendance" aria-label="Attendance">
               <p class="attendance-title">
                  <i class="fas fa-users" />
                  {`${attendees.length + (@isAttending ? 1 : 0)} Attending`}
               </p>

               <div class="attendance-list" role="list">
                  for (let attendee of attendees) {
                     <article class="attendee" role="listitem">
                        <img class="attendee-avatar" src={attendee.avatar} alt={`${attendee.name} profile`} />
                        <p class="attendee-name">{attendee.name}</p>
                     </article>
                  }
               </div>

               <div class="button-group">
                  <button
                     class={`button ${@isAttending ? "red" : "green"}`}
                     type="button"
                     onClick={toggleAttendance}
                  >
                     <i class={`fas ${@isAttending ? "fa-user-minus" : "fa-user-plus"}`} />
                     {@isAttending ? "Leave" : "Join"}
                  </button>
                  <button class="button" type="button" onClick={inviteOthers}>
                     <i class="fas fa-paper-plane" />
                     {"Share"}
                  </button>
               </div>
            </section>
         </div>
      </article>
   </div>

   <style scoped>
