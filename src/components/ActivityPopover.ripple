         z-index: 9999;
         animation: popover-backdrop-in 0.6s var(--ease) both;
      }

      .activity {
         font-size: 1.4rem;
         display: flex;
         flex-direction: row;
         padding: 1.5rem 2rem;
         gap: 2rem;
         max-width: calc(100% - 5rem);
         max-height: calc(100% - 5rem);
