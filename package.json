{
   "name": "activitree",
   "version": "1.0.0",
   "description": "Event planning done right",
   "type": "module",
   "engines": {
      "node": ">=20.0.0"
   },
   "scripts": {
      "start": "vite",
      "dev": "vite",
      "clean:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean-dev.ps1",
      "dev:clean": "bun run clean:dev && vite",
      "build": "vite build",
      "lint": "eslint .",
      "serve": "vite preview",
      "format": "prettier --write .",
      "format:check": "prettier --check ."
   },
   "license": "MIT",
   "devDependencies": {
      "@ripple-ts/eslint-parser": "0.3.3",
      "@ripple-ts/eslint-plugin": "0.3.3",
      "@ripple-ts/prettier-plugin": "0.3.3",
      "@ripple-ts/typescript-plugin": "0.3.3",
      "@ripple-ts/vite-plugin": "0.3.3",
      "@types/node": "^25.4.0",
      "@typescript-eslint/parser": "^8.57.0",
      "eslint": "^9.39.4",
      "prettier": "^3.8.1",
      "typescript": "^5.9.3",
      "vite": "^7.3.1",
      "vitest": "^4.0.18"
   },
   "dependencies": {
      "ripple": "0.3.3",
      "ripple-router": "^1.0.1"
   },
   "packageManager": "bun@1.3.0"
}
